# Supersocks URL Scraper public deployment template
# Copy this file to .env, then change values marked CHANGE_ME.
# Do not commit your real .env, browser-profiles/, data/, cookies, or tokens.

# Optional. If set, POST /summarize, /read, and /markdown require:
#   Authorization: Bearer <token>
API_BEARER_TOKEN=CHANGE_ME_RANDOM_LONG_TOKEN

# Default summary length when callers omit length.
DEFAULT_SUMMARY_LENGTH=900

# Production-grade fallback posture for hostile/JS/paywall-heavy media.
# The server still tries fast HTTP/SEO first; browser is fallback, not first route.
BROWSER_FALLBACK=1
BROWSER_PROFILE_DIR=/browser-profiles/default
BROWSER_POST_LOAD_WAIT_MS=10000
BROWSER_MAX_CONCURRENCY=1

# Public fallback layers.
SEO_FALLBACK=1
ARCHIVE_FALLBACK=1
FETCH_STRATEGY_CACHE_PATH=/data/fetch-strategies.json

# Optional external summarizer. Leave local for standalone public operation.
# To use your own service: SUMMARY_PROVIDER=http and set SUMMARY_PROVIDER_URL.
SUMMARY_PROVIDER=local
SUMMARY_PROVIDER_URL=
SUMMARY_PROVIDER_TOKEN=
SUMMARY_PROVIDER_TIMEOUT=30

# Quiet noisy Chromium/Cloak font warnings in container logs.
CLOAKBROWSER_SUPPRESS_FONT_WARNING=1
